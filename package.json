{
  "name": "generated-ozon-seller-api-client",
  "version": "1.0.0",
  "description": "TypeScript client for Ozon Seller API",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "generate": "npx swagger-typescript-api generate --path ./swagger.json --output ./src/ --name OzonSellerAPI.ts --responses --add-readonly --route-types --enum-names-as-values --extract-request-params --extract-request-body --extract-response-body --extract-response-error --extract-enums --api-class-name OzonSellerAPI --patch --single-http-client",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ozon",
    "api",
    "seller",
    "client",
    "typescript",
    "rest"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
